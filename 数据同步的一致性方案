## 监控指标

```java
@Component
public class ESMetrics {
    @Autowired private MeterRegistry registry;

    // 记录ES更新耗时
    public void recordESUpdateTime(long ms) {
        Timer.builder("es.update.time")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(registry)
            .record(ms, TimeUnit.MILLISECONDS);
    }

    // 版本不一致告警
    public void recordVersionMismatch() {
        Counter.builder("data.mismatch").register(registry).increment();
    }

    // 降级到MySQL次数
    public void recordFallback() {
        Counter.builder("fallback.mysql").register(registry).increment();
    }
}
```

